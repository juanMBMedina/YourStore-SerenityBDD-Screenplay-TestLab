def extractPropertyValue(String file, String property) {
    return sh(script: "grep \"^${property}=\" ${file} | sed \"s/^${property}=//\"", returnStdout: true).trim()
}

pipeline {
    agent any

    parameters {
        string(name: 'REPO_URL', defaultValue: 'git@github.com:juanMBMedina/YourStore-SerenityBDD-Screenplay-TestLab.git', description: 'SSH URL of the repository')
        string(name: 'DEFAULT_BRANCH', defaultValue: 'develop', description: 'Branch of the repository')
    }

    environment {
        BASE_DIR = '/var/jenkins_home/repos'
    }

    stages {
        stage('Prepare Environment') {
            steps {
                script {
                    env.PROJECT_NAME = extractPropertyValue('sonar-scanner.properties', 'sonar.projectName')
                    env.REPO_DIR = "${env.BASE_DIR}/${env.PROJECT_NAME}"
                    echo "Project: ${env.PROJECT_NAME}"
                    echo "Repo Directory: ${env.REPO_DIR}"
                }
            }
        }

        stage('Build Project All Project') {
            steps {
                script {
                    build(
                        job: "Run-Test-Suite-${env.PROJECT_NAME}",
                        parameters: [
                            string(name: 'SUITE', value: 'AllTests'),
                            string(name: 'BROWSER', value: 'Chrome'),
                            string(name: 'PROJECT_NAME', value: env.PROJECT_NAME)
                        ]
                    )
                }
            }
        }

        stage('Run SonarQube Analysis') {
            steps {
                script {
                    build(
                        job: 'scan-code',
                        parameters: [
                            string(name: 'REPO_DIR', value: env.REPO_DIR)
                        ]
                    )
                }
            }
        }
    }
}
