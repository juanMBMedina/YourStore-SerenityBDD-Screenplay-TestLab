pipeline {
    agent any

    parameters {
        string(name: 'PROJECT_NAME', defaultValue: 'YourStore-SerenityBDD-Screenplay-TestLab', description: 'Project Base Directory Repo')
        string(name: 'REPO_URL', defaultValue: 'git@github.com:juanMBMedina/YourStore-SerenityBDD-Screenplay-TestLab.git', description: 'SSH URL of the repository')
        string(name: 'DEFAULT_BRANCH', defaultValue: 'develop', description: 'Branch of the repository')
    }

    environment {
        BASE_DIR = '/var/jenkins_home/repos'
    }

    stages {

        stage('Build Project') {
            steps {
                script {
                    def repoDir = "${BASE_DIR}/${PROJECT_NAME}"
                    build(
                        job: 'Run-Test-Suites-YourStore-SerenityBDD-Screenplay-TestLab',
                        parameters: [
                            string(name: 'SUITE', value: 'AllTests'),
                            string(name: 'BROWSER', value: 'Chrome'),
                            string(name: 'PROJECT_NAME', value: PROJECT_NAME)
                        ]
                    )
                }
            }
        }

        stage('Running Sonarqube checking') {
            steps {
                script {
                    def repoDir = "${BASE_DIR}/${PROJECT_NAME}"
                    build(
                        job: 'scan-code',
                        parameters: [
                            string(name: 'REPO_DIR', value: repoDir),
                        ]
                    )
                }
            }
        }
    }
}
