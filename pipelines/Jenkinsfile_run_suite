def validateExist(directory, mssg = "The element \${directory} doesn't exist.") {
    if (!fileExists(directory)) {
        error mssg
    }
}

pipeline {
    agent any

    environment {
        BASE_DIR = '/var/jenkins_home/repos'
        REPORTS_DIR = '/var/jenkins_home/reports'
    }

    parameters {
        choice(
            name: 'SUITE',
            choices: ['AddToCartRunner', 'LoginRunner', 'RegisterRunner'],
            description: 'Select the test suite to run'
        )
        choice(
            name: 'BROWSER',
            choices: ['remoteChrome', 'remoteEdge', 'remoteFirefox'],
            description: 'Select the browser environment for test execution'
        )
        string(
            name: 'PROJECT_NAME',
            defaultValue: 'YourStore-Serenity-Screenplay-TestLab',
            description: 'Project base directory name'
        )
        string(
            name: 'REPO_URL',
            defaultValue: 'git@github.com:juanMBMedina/YourStore-Serenity-Screenplay-TestLab.git',
            description: 'SSH repository URL'
        )
        string(
            name: 'DEFAULT_BRANCH',
            defaultValue: 'develop',
            description: 'Repository branch to checkout'
        )
    }

    stages {

        stage('Clone Repository') {
            steps {
                script {
                    build job: 'get-repository', parameters: [
                        string(name: 'PROJECT_NAME', value: params.PROJECT_NAME),
                        string(name: 'REPO_URL', value: params.REPO_URL),
                        string(name: 'CLONE_DIR', value: BASE_DIR),
                        string(name: 'BRANCH', value: params.DEFAULT_BRANCH)
                    ]
                }
            }
        }

        stage('Start Selenium Grid') {
            steps {
                script {
                    def nodeService = ""
                    switch(params.BROWSER) {
                        case "remoteChrome":
                            nodeService = "chrome-node"
                            break
                        case "remoteEdge":
                            nodeService = "edge-node"
                            break
                        case "remoteFirefox":
                            nodeService = "firefox-node"
                            break
                        default:
                            error "Unsupported browser environment: ${params.BROWSER}"
                    }
                    echo "Starting selenium-hub and ${nodeService} containers using docker-compose.selenium.yml"
                    sh """
                        docker-compose -f docker-compose.selenium.yml up -d selenium-hub ${nodeService}
                    """

                    int maxRetries = 3
                    int retryCount = 0
                    int responseCode = 0

                    while (retryCount < maxRetries) {
                        responseCode = sh(
                            script: "curl -s -o /dev/null -w '%{http_code}' http://localhost:4444/status",
                            returnStdout: true
                        ).trim() as Integer

                        if (responseCode == 200) {
                            echo "Selenium-hub is up and running!"
                            break
                        } else {
                            echo "Selenium-hub not ready yet (HTTP ${responseCode}). Waiting 5 seconds..."
                            sleep 5
                            retryCount++
                        }
                    }

                    if (responseCode != 200) {
                        error "Selenium-hub did not become ready after ${maxRetries} attempts."
                    }
                }
            }
        }

        stage('Run Serenity Tests with Gradle') {
            steps {
                dir("${BASE_DIR}/${PROJECT_NAME}") {
                    script {
                        echo "Running Serenity tests for suite: ${params.SUITE} with environment: ${params.BROWSER}"
                        sh """
                            chmod +x ./functions.sh
                            ./run-test.sh ${params.SUITE} ${params.BROWSER}
                        """
                    }
                }
            }
        }


stage('Stop Selenium Grid') {
    steps {
        script {
            echo "Stopping selenium grid containers using docker-compose.selenium.yml"
            sh """
                docker-compose -f docker-compose.selenium.yml down
            """
        }
    }
}

        stage('Store Serenity Reports') {
            steps {
                dir("${BASE_DIR}/${PROJECT_NAME}") {
                    script {
                        def reportFolder = 'target/site/serenity'
                        def now = sh(script: "date +\"%Y-%m-%d_%H-%M-%S\"", returnStdout: true).trim()
                        def dest = "${REPORTS_DIR}/${params.PROJECT_NAME}/execution_${now}"
                        echo "Copying Serenity reports from ${reportFolder} to ${dest}"
                        sh """
                            mkdir -p ${dest}
                            cp -r ${reportFolder}/* ${dest}
                        """
                        // Guardamos la ruta para usarla en stages posteriores
                        env.SERENITY_REPORT_PATH = dest
                    }
                }
            }
        }

        stage('Publish Serenity Report') {
            steps {
                script {
                    publishHTML(target: [
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: env.SERENITY_REPORT_PATH,
                        reportFiles: 'index.html',
                        reportName: reportName: "${params.PROJECT_NAME} Serenity Report"
                    ])
                }
            }
        }

    }

    post {
        success {
            echo 'Tests executed successfully. Serenity report is available.'
        }
        failure {
            echo 'Tests failed. Please check the execution logs and generated report.'
        }
        always {
            echo 'Pipeline execution finished.'
        }
    }
}
